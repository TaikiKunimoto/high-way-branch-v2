<nodes>
    <!-- 本線(2車線)の始点 -->
    <node id="MainStart"   x="-50.0" y="0.0"   type="dead_end"/>
    <!-- オンランプが本線へ合流し、織込み区間(補助車線)が始まる地点 -->
    <node id="WeaveStart"  x="0.0"    y="0.0"   type="priority"/>
    <!-- 補助車線がオフランプ(出口)へ抜け、織込み区間が終わる地点 -->
    <node id="WeaveEnd"    x="200.0"  y="0.0"   type="priority"/>
    <!-- 本線終点 -->
    <node id="End"         x="296.0"  y="0.0"   type="dead_end"/>
    <!-- オンランプ(1車線)の始点。下側から進入 -->
    <node id="OnRampStart" x="-50.0" y="-12.0" type="dead_end"/>
    <!-- オフランプ(1車線)の終点。下側へ抜ける（一側織込み＝合流も分流も下側の補助車線を使う） -->
    <node id="ExitEnd"     x="300.0"  y="-50.0" type="dead_end"/>
</nodes>
