<routes>
    <vType id="CAV" accel="10.0" decel="5.0" maxSpeed="27" length="5" speedFactor="1.0" speedDev="0.0"/>
    <!-- 直進（必須LCなし）: 独立区間の本線 → 織込み区間 → tail -->
    <route id="r_main" edges="MainApproach WeaveZone MainLane"/>
    <!-- 合流: オンランプ → 織込み区間(補助車線) → 本線 tail -->
    <route id="r_ramp" edges="OnRamp WeaveZone MainLane"/>
    <!-- 分流: 本線 → 織込み区間(補助車線へ降りる) → オフランプ(出口) -->
    <route id="r_exit" edges="MainApproach WeaveZone ExitRamp"/>
</routes>
