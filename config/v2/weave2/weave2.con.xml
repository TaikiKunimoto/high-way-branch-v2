<connections>
    <!-- 本線2車線 → 織込みゾーンの本線 lane1,2 -->
    <connection from="MainApproach" to="WeaveZone" fromLane="0" toLane="1"/>
    <connection from="MainApproach" to="WeaveZone" fromLane="1" toLane="2"/>
    <!-- オンランプ → 加速車線 lane0(下) -->
    <connection from="OnRamp" to="WeaveZone" fromLane="0" toLane="0"/>
    <!-- 織込みゾーン本線 lane1,2 → tail 本線（lane0=加速車線は接続なし＝端で drop し締切を強制） -->
    <connection from="WeaveZone" to="MainLane" fromLane="1" toLane="0"/>
    <connection from="WeaveZone" to="MainLane" fromLane="2" toLane="1"/>
    <!-- 出口車線 lane3(上) → オフランプ -->
    <connection from="WeaveZone" to="ExitRamp" fromLane="3" toLane="0"/>
</connections>
