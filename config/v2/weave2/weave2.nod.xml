<nodes>
    <!-- 本線(2車線)の始点 -->
    <node id="MainStart" x="-100.0" y="0.0" type="dead_end"/>
    <!-- 織込みゾーンの始点。下側からオンランプ(加速車線 lane0)が連結する -->
    <node id="WeaveStart" x="0.0" y="0.0" type="priority"/>
    <!-- 織込みゾーンの終点。上側へオフランプ(出口車線 lane3)が分岐する -->
    <node id="WeaveEnd" x="400.0" y="0.0" type="priority"/>
    <!-- 本線終点 -->
    <node id="End" x="464.0" y="0.0" type="dead_end"/>
    <!-- オンランプ(1車線)の始点。下側から smoothstep で降下し lane0 レベル(-4.8)へ平行進入する -->
    <node id="OnRampStart" x="-100.0" y="-20.0" type="dead_end"/>
    <!-- オフランプ(1車線)の終点。lane3 から上へ滑らかに分流し本線と平行(水平)に伸ばす -->
    <node id="ExitEnd" x="458.0" y="9.8" type="dead_end"/>
</nodes>
